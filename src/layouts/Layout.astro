---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Outfit:wght@300;400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0a0a1a;
    --surface: #14142b;
    --text: #f0eef6;
    --muted: #9994b8;
    --accent: #ff6b9d;
    --accent2: #c44dff;
    --accent3: #00d4aa;
    --gold: #ffd166;
    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: "Outfit", sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    backdrop-filter: blur(20px);
    background: rgba(10, 10, 26, 0.6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: background 0.3s;
  }

  .nav-logo {
    font-family: "Fredoka", sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent), var(--accent2), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out-expo);
  }
  .nav-links a:hover {
    color: var(--text);
  }
  .nav-links a:hover::after {
    width: 100%;
  }

  .hero {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    background: rgba(255, 107, 157, 0.12);
    border: 1px solid rgba(255, 107, 157, 0.25);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 2rem;
  }
  .hero-badge .dot {
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }

  .hero h1 {
    font-family: "Fredoka", sans-serif;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1.5rem;
  }
  .hero h1 .line1 {
    display: block;
    background: linear-gradient(135deg, #fff 30%, var(--muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero h1 .line2 {
    display: block;
    background: linear-gradient(
      135deg,
      var(--accent),
      var(--accent2),
      var(--gold),
      var(--accent3)
    );
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--muted);
    max-width: 500px;
    margin-bottom: 2.5rem;
  }

  .hero-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .hero-price .currency {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--gold);
  }
  .hero-price .amount {
    font-family: "Fredoka", sans-serif;
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    color: var(--gold);
    text-shadow: 0 0 40px rgba(255, 209, 102, 0.3);
  }
  .hero-price .unit {
    font-size: 1.1rem;
    color: var(--muted);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    border: none;
    border-radius: 100px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    font-family: "Outfit", sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.4s var(--ease-out-expo);
    box-shadow: 0 8px 32px rgba(37, 211, 102, 0.3);
    position: relative;
    overflow: hidden;
  }
  .cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      transparent,
      rgba(255, 255, 255, 0.15),
      transparent
    );
    transform: translateX(-100%);
    transition: transform 0.6s var(--ease-out-expo);
  }
  .cta-btn:hover {
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 16px 48px rgba(37, 211, 102, 0.4);
  }
  .cta-btn:hover::before {
    transform: translateX(100%);
  }
  .cta-btn svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
  }
  .scroll-hint svg {
    width: 32px;
    height: 32px;
    stroke: var(--muted);
    stroke-width: 2;
    fill: none;
  }

  .section {
    position: relative;
    z-index: 2;
    padding: 6rem 2rem;
  }

  .section-title {
    text-align: center;
    margin-bottom: 1rem;
  }
  .section-title h2 {
    font-family: "Fredoka", sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
  }
  .section-title .highlight {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-subtitle {
    text-align: center;
    color: var(--muted);
    font-size: 1.1rem;
    margin-bottom: 4rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .product-card {
    background: var(--surface);
    border-radius: 24px;
    padding: 2rem;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.5s var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 0%,
      var(--card-accent, var(--accent)),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quart);
  }
  .product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.3);
  }
  .product-card:hover::before {
    opacity: 0.08;
  }

  .product-img {
    width: 100%;
    max-width: 220px;
    height: auto;
    border-radius: 16px;
    margin: 0 auto 1.5rem;
    display: block;
    transition: transform 0.5s var(--ease-out-expo);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }
  .product-card:hover .product-img {
    transform: scale(1.05);
  }

  .flavor-arequipe {
    --card-accent: #f5c77e;
  }
  .flavor-bocadillo {
    --card-accent: #ff8fab;
  }
  .flavor-coco {
    --card-accent: #f5f0e8;
  }
  .flavor-cola {
    --card-accent: #8b4513;
  }
  .flavor-maraculla {
    --card-accent: #ffa94d;
  }
  .flavor-oreo {
    --card-accent: #555;
  }

  .product-name {
    font-family: "Fredoka", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    position: relative;
  }
  .product-desc {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    position: relative;
  }
  .product-price-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 1.2rem;
    border-radius: 100px;
    background: rgba(255, 209, 102, 0.12);
    border: 1px solid rgba(255, 209, 102, 0.25);
    font-family: "Fredoka", sans-serif;
    font-weight: 700;
    color: var(--gold);
    font-size: 1.2rem;
    position: relative;
  }

  .ice-section {
    background: linear-gradient(
      180deg,
      transparent,
      rgba(0, 212, 170, 0.05),
      transparent
    );
  }

  .ice-card {
    max-width: 600px;
    margin: 0 auto;
    background: var(--surface);
    border-radius: 32px;
    padding: 3rem;
    text-align: center;
    border: 1px solid rgba(0, 212, 170, 0.15);
    position: relative;
    overflow: hidden;
  }
  .ice-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 50% 0%,
      var(--accent3),
      transparent 60%
    );
    opacity: 0.06;
  }

  .ice-cubes {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    position: relative;
  }
  .ice-cube {
    width: 60px;
    height: 60px;
    background: linear-gradient(
      135deg,
      rgba(200, 230, 255, 0.6),
      rgba(150, 200, 255, 0.3)
    );
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    position: relative;
  }
  .ice-cube::before {
    content: "";
    position: absolute;
    top: 8px;
    left: 8px;
    width: 20px;
    height: 20px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    transform: rotate(15deg);
  }
  .ice-cube:nth-child(2) {
    transform: rotate(5deg);
  }
  .ice-cube:nth-child(3) {
    transform: rotate(-3deg);
  }

  .ice-title {
    font-family: "Fredoka", sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent3);
    margin-bottom: 0.5rem;
  }
  .ice-price {
    font-family: "Fredoka", sans-serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  .ice-desc {
    color: var(--muted);
    font-size: 1rem;
  }

  .delivery-section {
    text-align: center;
  }

  .delivery-card {
    max-width: 700px;
    margin: 0 auto;
    background: var(--surface);
    border-radius: 32px;
    padding: 3rem;
    border: 1px solid rgba(255, 107, 157, 0.15);
    position: relative;
    overflow: hidden;
  }

  .delivery-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .delivery-card h3 {
    font-family: "Fredoka", sans-serif;
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: var(--accent);
  }

  .conditions {
    list-style: none;
    text-align: left;
    max-width: 400px;
    margin: 0 auto;
  }
  .conditions li {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .conditions li:last-child {
    border-bottom: none;
  }
  .conditions .check {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(0, 212, 170, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--accent3);
    font-size: 0.8rem;
  }

  .order-section {
    text-align: center;
    padding: 6rem 2rem 8rem;
  }
  .order-section h2 {
    font-family: "Fredoka", sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }
  .order-section p {
    color: var(--muted);
    font-size: 1.1rem;
    margin-bottom: 2.5rem;
  }

  .big-cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 3rem;
    border: none;
    border-radius: 100px;
    background: linear-gradient(135deg, #25d366, #128c7e);
    color: #fff;
    font-family: "Outfit", sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.4s var(--ease-out-expo);
    box-shadow: 0 12px 40px rgba(37, 211, 102, 0.35);
    position: relative;
    overflow: hidden;
  }
  .big-cta:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 20px 60px rgba(37, 211, 102, 0.45);
  }
  .big-cta svg {
    width: 28px;
    height: 28px;
    fill: currentColor;
  }

  .phone-number {
    display: block;
    margin-top: 1.5rem;
    font-family: "Fredoka", sans-serif;
    font-size: 1.5rem;
    color: var(--text);
    letter-spacing: 2px;
  }

  footer {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem;
    color: var(--muted);
    font-size: 0.85rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .wa-float {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 999;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.4);
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
  }
  .wa-float:hover {
    transform: scale(1.1);
    box-shadow: 0 12px 32px rgba(37, 211, 102, 0.5);
  }
  .wa-float svg {
    width: 32px;
    height: 32px;
    fill: #fff;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .products-grid {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
    }
    .hero {
      padding-top: 5rem;
    }
  }
  @media (max-width: 480px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
    nav {
      padding: 0.75rem 1rem;
    }
  }
</style>
